# ApplyMind AI — Backend Environment Variables
# Copy to .env and fill values. NEVER commit .env to git.

# ─── Groq AI ─────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Firebase Admin SDK (server-side) ─────────────────────────────────
# Option 1: JSON string of the service account (best for cloud deployments)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option 2: Path to service account file (local dev only)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

FIREBASE_PROJECT_ID=your-project-id

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/applymind
# Railway: DATABASE_URL is auto-set

# ─── Redis (caching + rate limiting) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Upstash: redis://default:password@your-endpoint.upstash.io:6379

# ─── Security ─────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
ENVIRONMENT=development   # or: production

# ─── Credential vault (AES-256) ───────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ─── Email / SMTP (for application cover letter emails) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Sentry ───────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── App settings ─────────────────────────────────────────────────────
DAILY_APP_LIMIT=200
MAX_JOBS_PER_SCRAPE=100
