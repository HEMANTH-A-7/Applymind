# ApplyMind frontend — copy to .env.local and fill from Firebase console
# (Project settings → General → Your apps → SDK setup and configuration)
# These are NEXT_PUBLIC_ on purpose: they ship in the JS bundle; Firebase
# Security Rules protect the data, not these keys.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Backend API base URL (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000
